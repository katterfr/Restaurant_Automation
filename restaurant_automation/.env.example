# ════════════════════════════════════════════════════════════════
#  Restaurant Automation Platform — Environment Variables
#  Copy to .env and fill in your values before running.
# ════════════════════════════════════════════════════════════════

# ── Restaurant Identity ─────────────────────────────────────────
RESTAURANT_NAME=My Restaurant
RESTAURANT_TIMEZONE=America/New_York
BUSINESS_OPEN_TIME=11:00
BUSINESS_CLOSE_TIME=22:00

# ── OpenAI (GPT-4o phone agent brain) ──────────────────────────
OPENAI_API_KEY=sk-...

# ── Twilio (inbound calls + SMS) ───────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ── Database ────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/restaurant.db
# Production PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/restaurant

# ── Redis (event bus + session cache) ───────────────────────────
REDIS_URL=redis://localhost:6379

# ── Website Sync ────────────────────────────────────────────────
WEBSITE_API_URL=https://yoursite.com/api
WEBSITE_API_KEY=...

# ── DoorDash Drive API ──────────────────────────────────────────
DOORDASH_DEVELOPER_ID=
DOORDASH_KEY_ID=
DOORDASH_SIGNING_SECRET=
DOORDASH_BASE_URL=https://openapi.doordash.com

# ── Uber Eats Orders API ────────────────────────────────────────
UBEREATS_CLIENT_ID=
UBEREATS_CLIENT_SECRET=
UBEREATS_STORE_ID=
UBEREATS_BASE_URL=https://api.uber.com

# ── Email Alerts ────────────────────────────────────────────────
EMAIL_ALERTS_ENABLED=true
EMAIL_PROVIDER=sendgrid          # sendgrid | smtp

# Sender address (must be verified in SendGrid or your SMTP account)
ALERT_EMAIL_FROM=noreply@myrestaurant.com
# Comma-separated recipient(s)
ALERT_EMAIL_TO=owner@myrestaurant.com
ALERT_EMAIL_CC=

# SendGrid (recommended — free 100 emails/day)
SENDGRID_API_KEY=SG....

# SMTP fallback (Gmail, Outlook, custom)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=                   # Use a Gmail App Password, not your real password

# Low-stock alert cooldown — min minutes between repeat alerts per SKU
LOW_STOCK_ALERT_COOLDOWN_MINUTES=60

# ── Ngrok (local dev tunnel for Twilio webhooks) ────────────────
NGROK_AUTHTOKEN=
