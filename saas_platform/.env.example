# ══════════════════════════════════════════════════════════════════
#  Restaurant Automation — SaaS Platform Environment Variables
#  Copy to .env and fill in your values before running.
# ══════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────
APP_NAME=Restaurant Automation SaaS
APP_ENV=development          # development | production
APP_PORT=8001
SECRET_KEY=change-me-to-a-long-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./saas.db

# ── Stripe Billing ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...      # Starter plan price ID
STRIPE_PRICE_PRO=price_...          # Pro plan price ID
STRIPE_PRICE_ENTERPRISE=price_...   # Enterprise plan price ID

# ── Email (SendGrid) ─────────────────────────────────────────────
SENDGRID_API_KEY=SG....
EMAIL_FROM=noreply@yourdomain.com

# ── Supabase ─────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Admin ────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=changeme
